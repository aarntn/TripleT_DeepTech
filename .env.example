# DUST_SCALER_SHA256=
API_HOST=127.0.0.1
API_PORT=8000

# Optional real weather integration.
WEATHER_PROVIDER=synthetic
WEATHER_LAT=3.139
WEATHER_LON=101.6869
WEATHER_PROCESSED_PATH=data/processed/weather/forecast_weather.csv
